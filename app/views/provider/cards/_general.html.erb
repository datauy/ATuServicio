<div class="card <%= card[:name] %>">
  <div class="card-header">
    <div class="header-top"></div>
    <h3><%= card[:title] %></h3>
  </div>
  <div class="card-content">
    <div class="values users-total">Cantitdad de usuarios: <div class="result"><%= card['total'] %></div></div>
    <div class="values">Usuarios fonasa: <div class="result"><%= card['fonasa_users'] %></div></div>
    <div class="values">Usuarios no fonasa: <div class="result"><%= card['no_fonasa_users'] %></div></div>
  </div>
</div>