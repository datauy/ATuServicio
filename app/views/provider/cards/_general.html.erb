<div class="card <%= card[:name] %>">
  <div class="card-header">
    <div class="header-top">
      <i class='fas fa-file'></i>
      <%= button_tag "<i class='fas fa-circle-info'></i>".html_safe, data: {'tabs-tab-value': "prestadores", action: "tabs#switch_tab"} %>
    </div>
    <h3><%= card[:title] %></h3>
    <div class="border-bottom"></div>
  </div>
  <div class="card-content">
    <div class="values users-total">Cantitdad de usuarios: <div class="result"><%= number_with_delimiter(card['total'], {delimiter: '.'}) %></div></div>
    <div class="values">Usuarios fonasa: <div class="result"><%= number_with_delimiter(card['fonasa_users'], {delimiter: '.'} )%></div></div>
    <div class="values">Usuarios no fonasa: <div class="result"><%= number_with_delimiter(card['no_fonasa_users'], {delimiter: '.'} )%></div></div>
  </div>
</div>